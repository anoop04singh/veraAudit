# Server
PORT=4000
NODE_ENV=development

# Tatum Sui RPC (mainnet)
TATUM_API_KEY=your_tatum_key
TATUM_SUI_RPC=https://sui-mainnet.gateway.tatum.io
TATUM_WALRUS_UPLOAD_URL=https://api.tatum.io/v4/data/storage/upload
TATUM_WALRUS_STATUS_POLL_MS=5000
TATUM_WALRUS_STATUS_MAX_ATTEMPTS=36

# Walrus reads
WALRUS_NETWORK=mainnet
WALRUS_AGGREGATOR=https://aggregator.walrus-mainnet.walrus.space

# Gemini
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# Sui Move registry anchor settings
REGISTRY_PACKAGE_ID=0x...
REGISTRY_OBJECT_ID=0x...
ADMIN_CAP_OBJECT_ID=0x...
SUI_CLOCK_OBJECT_ID=0x6
SUI_PRIVATE_KEY=suiprivkey...

APP_NETWORK_LABEL=sui:mainnet

# Retry and pipeline tuning
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_MS=1500
RETRY_MAX_DELAY_MS=30000
TATUM_MIN_INTERVAL_MS=450
SUI_ANCHOR_RPC_FALLBACK=https://fullnode.mainnet.sui.io:443
CONTEXT_MODULE_QUERY_CONCURRENCY=2
MAX_CONTEXT_EVENTS=50
MAX_MODULE_CHARS_FOR_AUDIT=120000
MAX_EVENT_CHARS_FOR_AUDIT=30000
